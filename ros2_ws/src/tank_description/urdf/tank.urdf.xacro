<?xml version="1.0"?>
<!--
  Makis Mecanum Tank URDF
  Body dimensions (approximate):
    Length  (x) = 0.28 m
    Width   (y) = 0.22 m
    Height  (z) = 0.08 m
  Wheel: diameter 0.065 m, width 0.03 m
  Wheel positions (from base_footprint):
    FL: x= 0.09  y= 0.125  z= 0.0325
    FR: x= 0.09  y=-0.125  z= 0.0325
    RL: x=-0.09  y= 0.125  z= 0.0325
    RR: x=-0.09  y=-0.125  z= 0.0325
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="makis_tank">

  <!-- ── Properties ──────────────────────────────────────── -->
  <xacro:property name="body_l"    value="0.28"/>
  <xacro:property name="body_w"    value="0.22"/>
  <xacro:property name="body_h"    value="0.08"/>
  <xacro:property name="wheel_r"   value="0.0325"/>
  <xacro:property name="wheel_w"   value="0.03"/>
  <xacro:property name="wx"        value="0.09"/>
  <xacro:property name="wy"        value="0.125"/>
  <xacro:property name="M_PI"      value="3.14159265"/>

  <!-- ── Materials ─────────────────────────────────────── -->
  <material name="dark_grey">  <color rgba="0.2 0.2 0.2 1.0"/> </material>
  <material name="orange">     <color rgba="0.9 0.5 0.1 1.0"/> </material>
  <material name="black">      <color rgba="0.0 0.0 0.0 1.0"/> </material>
  <material name="green">      <color rgba="0.1 0.7 0.1 1.0"/> </material>

  <!-- ── Wheel macro ────────────────────────────────────── -->
  <xacro:macro name="mecanum_wheel" params="prefix x y">
    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.15"/>
        <origin xyz="0 0 0" rpy="${M_PI/2} 0 0"/>
        <inertia ixx="0.000125" ixy="0" ixz="0"
                 iyy="0.000125" iyz="0" izz="0.000237"/>
      </inertial>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel"/>
      <origin xyz="${x} ${y} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ── base_footprint ────────────────────────────────── -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_r}" rpy="0 0 0"/>
  </joint>

  <!-- ── base_link (chassis) ───────────────────────────── -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${body_h/2}" rpy="0 0 0"/>
      <geometry><box size="${body_l} ${body_w} ${body_h}"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${body_h/2}" rpy="0 0 0"/>
      <geometry><box size="${body_l} ${body_w} ${body_h}"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 ${body_h/2}"/>
      <inertia ixx="0.0110" ixy="0" ixz="0"
               iyy="0.0170" iyz="0" izz="0.0264"/>
    </inertial>
  </link>

  <!-- ── Wheels ──────────────────────────────────────── -->
  <xacro:mecanum_wheel prefix="fl" x=" ${wx}" y=" ${wy}"/>
  <xacro:mecanum_wheel prefix="fr" x=" ${wx}" y="-${wy}"/>
  <xacro:mecanum_wheel prefix="rl" x="-${wx}" y=" ${wy}"/>
  <xacro:mecanum_wheel prefix="rr" x="-${wx}" y="-${wy}"/>

  <!-- ── LiDAR ─────────────────────────────────────────── -->
  <link name="laser">
    <visual>
      <geometry><cylinder radius="0.035" length="0.04"/></geometry>
      <material name="orange"/>
    </visual>
    <inertial>
      <mass value="0.17"/>
      <inertia ixx="0.0" ixy="0" ixz="0" iyy="0.0" iyz="0" izz="0.0"/>
    </inertial>
  </link>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser"/>
    <origin xyz="0 0 ${body_h + 0.025}" rpy="0 0 0"/>
  </joint>

  <!-- ── IMU ───────────────────────────────────────────── -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 ${body_h/2}" rpy="0 0 0"/>
  </joint>

  <!-- ── Camera ────────────────────────────────────────── -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.025 0.025 0.025"/></geometry>
      <material name="green"/>
    </visual>
    <inertial>
      <mass value="0.03"/>
      <inertia ixx="0.0" ixy="0" ixz="0" iyy="0.0" iyz="0" izz="0.0"/>
    </inertial>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="${body_l/2 - 0.01} 0 ${body_h/2}" rpy="0 0 0"/>
  </joint>
  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_frame"/>
    <!-- ROS camera convention: z forward, x right, y down (rotate -90° pitch, -90° yaw) -->
    <origin xyz="0 0 0" rpy="${-M_PI/2} 0 ${-M_PI/2}"/>
  </joint>

</robot>
